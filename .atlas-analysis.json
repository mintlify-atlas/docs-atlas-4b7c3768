  "keyFeatures": [
    "Citizen registration with CURP and INE document upload",
    "Admin user approval/rejection workflow with email notifications",
    "Geo-located incident reporting via mobile API",
    "Firebase push notifications for incident status updates",
    "Admin web panel with incident management and statistics dashboard",
    "Google OAuth login via Firebase",
    "6-digit PIN-based password recovery via email",
    "Laravel Sanctum token-based API authentication",
    "Incident heatmap visualization and per-category statistics"
  ],
  "publicApiSurface": [
    "POST /api/register",
